#!/usr/bin/env bash

# Generates ~/.config/gtk-4.0/gtk.css from a dotshell theme JSON file.
# Maps the 19 dotshell semantic color tokens to GTK @define-color variables
# so that GTK 4 apps visually match the active shell theme.
#
# Usage: generate-gtk-css <theme-json-path>

set -euo pipefail

readonly GTK4_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/gtk-4.0"
readonly GTK4_CSS="$GTK4_DIR/gtk.css"

die() {
  echo "error: $*" >&2
  exit 1
}

[[ -z "${1:-}" ]] && die "usage: generate-gtk-css <theme-json-path>"
[[ -f "$1" ]] || die "theme file not found: $1"

theme="$1"

# Extract colors from the theme JSON
color() { jq -r ".$1" "$theme"; }

bg_base=$(color bgBase)
bg_base_alt=$(color bgBaseAlt)
bg_deep=$(color bgDeep)
bg_card=$(color bgCard)
text_primary=$(color textPrimary)
accent=$(color accent)
success=$(color success)
warning=$(color warning)
danger=$(color danger)

mkdir -p "$GTK4_DIR"

cat >"$GTK4_CSS" <<EOF
/* Generated by dotshell generate-gtk-css — do not edit manually */

/* Accent */
@define-color accent_bg_color ${accent};
@define-color accent_fg_color ${bg_deep};
@define-color accent_color ${accent};

/* Destructive / error */
@define-color destructive_bg_color ${danger};
@define-color destructive_fg_color ${bg_deep};
@define-color destructive_color ${danger};
@define-color error_bg_color ${danger};
@define-color error_fg_color ${bg_deep};
@define-color error_color ${danger};

/* Success */
@define-color success_bg_color ${success};
@define-color success_fg_color ${bg_deep};
@define-color success_color ${success};

/* Warning */
@define-color warning_bg_color ${warning};
@define-color warning_fg_color ${bg_deep};
@define-color warning_color ${warning};

/* Window */
@define-color window_bg_color ${bg_base_alt};
@define-color window_fg_color ${text_primary};

/* View */
@define-color view_bg_color ${bg_base_alt};
@define-color view_fg_color ${text_primary};

/* Header bar */
@define-color headerbar_bg_color ${bg_base_alt};
@define-color headerbar_fg_color ${text_primary};

/* Sidebar */
@define-color sidebar_bg_color ${bg_base};
@define-color sidebar_fg_color ${text_primary};

/* Secondary sidebar */
@define-color secondary_sidebar_bg_color ${bg_base_alt};
@define-color secondary_sidebar_fg_color ${text_primary};

/* Card */
@define-color card_bg_color ${bg_card};
@define-color card_fg_color ${text_primary};

/* Tab overview */
@define-color overview_bg_color ${bg_base};
@define-color overview_fg_color ${text_primary};

/* Popover */
@define-color popover_bg_color ${bg_base};
@define-color popover_fg_color ${text_primary};

/* Dialog */
@define-color dialog_bg_color ${bg_base_alt};
@define-color dialog_fg_color ${text_primary};

/* Backdrop / unfocused states */
@define-color headerbar_backdrop_color @window_bg_color;
@define-color sidebar_backdrop_color @sidebar_bg_color;
@define-color theme_unfocused_fg_color @window_fg_color;
@define-color theme_unfocused_text_color @view_fg_color;
@define-color theme_unfocused_bg_color @window_bg_color;
@define-color theme_unfocused_base_color @window_bg_color;
@define-color theme_unfocused_selected_bg_color @accent_bg_color;
@define-color theme_unfocused_selected_fg_color @accent_fg_color;
EOF
