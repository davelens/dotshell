#!/bin/sh
# Turnstile-managed polkit authentication agent for Void Linux.
exec 2>&1

[ -n "${TURNSTILE_ENV_DIR:-}" ] || { sleep 2; exit 1; }
[ -r "$TURNSTILE_ENV_DIR/DBUS_SESSION_BUS_ADDRESS" ] || { sleep 2; exit 1; }
if [ ! -r "$TURNSTILE_ENV_DIR/WAYLAND_DISPLAY" ] \
    && [ ! -r "$TURNSTILE_ENV_DIR/DISPLAY" ]; then
  sleep 2
  exit 1
fi

exec chpst -e "$TURNSTILE_ENV_DIR" /usr/bin/lxqt-policykit-agent
