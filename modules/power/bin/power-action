#!/usr/bin/env bash
set -euo pipefail

script_path="$(readlink -f "${BASH_SOURCE[0]}")"
backend_dir="$(cd "$(dirname "$script_path")/../backends" && pwd)"

if [[ ! -r /etc/os-release ]]; then
  echo "error: cannot detect distribution (/etc/os-release is missing)" >&2
  exit 1
fi

# shellcheck source=/dev/null
. /etc/os-release
backend="$backend_dir/${ID:-unknown}.sh"

if [[ ! -r "$backend" ]]; then
  echo "error: no power backend for distribution '${ID:-unknown}'" >&2
  exit 1
fi

# shellcheck source=/dev/null
. "$backend"

if ! declare -F perform_action >/dev/null; then
  echo "error: power backend '$backend' does not implement perform_action" >&2
  exit 1
fi

perform_action "${1:-}"
