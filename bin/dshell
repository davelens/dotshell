#!/usr/bin/env bash

# This is a CLI companion to dotshell. It's intended to be a functional,
# autocompleted replacement for `qs ipc call` instructions.
#
# The COMMANDS registry below is the single source of truth for the CLI
# surface: dispatch, usage text, and bash completion (`dshell --complete`)
# are all generated from it. Adding a subcommand means adding one row
# (plus its IpcHandler function on the QML side).

set -euo pipefail

readonly CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/dotshell"
readonly DATA_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/dotshell"
readonly BUNDLED_THEMES_DIR="$CONFIG_DIR/themes"
readonly USER_THEMES_DIR="$DATA_DIR/themes"
readonly GENERAL_JSON="$DATA_DIR/general.json"

# -- command registry ----------------------------------------------------------
#
# Format: "path|handler|args|description"
#   path        words after `dshell`, matched verbatim
#   handler     "ipc <target> <function>" or "fn <local function>"
#   args        space-separated tokens; <x> required, [x] optional.
#               A :source suffix names the completion source
#               (theme, profile, category, popup, file).
#   description one line, shown in usage

readonly -a COMMANDS=(
  "bar focus toggle|ipc bar toggle||Toggle bar focus mode"
  "bar focus enable|ipc bar enable||Enable bar focus mode"
  "bar focus disable|ipc bar disable||Disable bar focus mode"
  "bar focus state|ipc bar state||Show bar focus state"
  "idle enable|ipc idle enable||Enable idle inhibitor"
  "idle disable|ipc idle disable||Disable idle inhibitor"
  "idle toggle|ipc idle toggle||Toggle idle inhibitor"
  "idle state|ipc idle state||Show idle inhibitor state"
  "notifications toggle|ipc overlay toggle notifications||Toggle notification panel"
  "notifications open|ipc overlay open notifications||Open notification panel"
  "notifications close|ipc overlay close notifications||Close notification panel"
  "notifications dismiss|ipc notifications dismiss|<id>|Dismiss a notification by id"
  "notifications clear-all|ipc notifications clearAll||Clear notification history"
  "popup toggle|ipc popup toggle|<name:popup>|Toggle a popup (e.g. volume, brightness)"
  "power toggle|ipc overlay toggle power||Toggle power menu"
  "power open|ipc overlay open power||Open power menu"
  "power close|ipc overlay close power||Close power menu"
  "profile list|fn profile_list||List all profiles"
  "profile current|fn profile_current||Show active profile name"
  "profile set|ipc profile set|<name:profile>|Switch to a profile"
  "screen-recording files toggle|ipc overlay toggle recording||Toggle the screen recording file browser"
  "screen-recording files open|ipc overlay open recording||Open the screen recording file browser"
  "screen-recording files close|ipc overlay close recording||Close the screen recording file browser"
  "settings toggle|ipc overlay toggle settings||Toggle settings panel"
  "settings open|ipc overlay open settings||Open settings panel"
  "settings close|ipc overlay close settings||Close settings panel"
  "settings show-category|ipc settings showCategory|<id:category>|Open settings panel to a category"
  "theme list|fn theme_list||List available themes"
  "theme set|fn theme_set|<name:theme>|Switch to a theme"
  "theme current|fn active_theme||Show active theme name"
  "theme refresh|fn theme_refresh||Regenerate GTK CSS for the active theme"
  "wallpaper browser toggle|ipc overlay toggle wallpaper||Toggle the wallpaper browser"
  "wallpaper browser open|ipc overlay open wallpaper||Open the wallpaper browser"
  "wallpaper browser close|ipc overlay close wallpaper||Close the wallpaper browser"
  "wallpaper set|fn wallpaper_set|<path:file>|Set a wallpaper by file path"
  "wallpaper restore|fn wallpaper_restore|[fallback:file]|Restore saved wallpaper (optional fallback)"
)

readonly -a GROUP_DESCRIPTIONS=(
  "bar|Bar focus mode"
  "idle|Idle inhibitor control"
  "notifications|Notification panel and history"
  "popup|Popup windows"
  "power|Power menu"
  "profile|Profile management"
  "screen-recording|Screen recording file browser"
  "settings|Settings panel"
  "theme|Theme management"
  "wallpaper|Wallpaper browser and setter"
)

# -- helpers -----------------------------------------------------------------

die() {
  echo "error: $*" >&2
  exit 1
}

# IPC seam: QML handlers return feedback strings; an "error:" prefix
# becomes stderr + non-zero exit (qs itself always exits 0).
ipc() {
  local out
  out="$(qs -p "$CONFIG_DIR" ipc call "$@")"
  if [[ "$out" == error:* ]]; then
    echo "$out" >&2
    return 1
  fi
  [[ -n "$out" ]] && echo "$out"
  return 0
}

# Strip the :source suffixes from an args spec for display
display_spec() {
  [[ -z "$1" ]] && return 0
  echo "$1" | sed 's/:[a-z-]*\([]>]\)/\1/g'
}

# State-read seam: every read of a dotshell JSON state file goes through
# here. Mutations go through ipc(); reads never do — the files are
# authoritative (QML saves on every change) and must work with the shell
# down (e.g. `wallpaper restore` at compositor startup).
json_get() { # json_get <file> <jq-filter> [default]
  local file="$1" filter="$2" default="${3:-}"
  local val=""
  if [[ -f "$file" ]]; then
    val="$(jq -r "$filter // empty" "$file")"
  fi
  if [[ -n "$val" ]]; then
    printf '%s\n' "$val"
  elif [[ -n "$default" ]]; then
    printf '%s\n' "$default"
  fi
  return 0
}

# -- completion value sources --------------------------------------------------

# All theme names; user themes override bundled ones by name
themes_all() {
  local f base
  for f in "$BUNDLED_THEMES_DIR"/*.json "$USER_THEMES_DIR"/*.json; do
    [[ -f "$f" ]] || continue
    base="${f##*/}"
    echo "${base%.json}"
  done | sort -u
  return 0
}

profile_names() {
  json_get "$GENERAL_JSON" '.profiles[]?.name'
}

settings_categories() {
  json_get "$GENERAL_JSON" '.settingsCategoryOrder[]?'
}

popup_modules() {
  jq -r 'select(.components.popup != null) | .id' \
    "$CONFIG_DIR"/modules/*/module.json 2>/dev/null || true
}

# -- theme -------------------------------------------------------------------

# Read the active theme name from general.json (falls back to catppuccin-mocha)
active_theme() {
  json_get "$GENERAL_JSON" '.theme' catppuccin-mocha
}

# Resolve the full path to a theme JSON file (user overrides take precedence)
resolve_theme_path() {
  if [[ -f "$USER_THEMES_DIR/$1.json" ]]; then
    echo "$USER_THEMES_DIR/$1.json"
  elif [[ -f "$BUNDLED_THEMES_DIR/$1.json" ]]; then
    echo "$BUNDLED_THEMES_DIR/$1.json"
  fi
}

theme_exists() {
  [[ -n "$(resolve_theme_path "$1")" ]]
}

# Regenerate GTK 4 CSS from a theme JSON file
update_gtk_css() {
  local script_dir
  script_dir="$(dirname "$(readlink -f "$0")")"
  local theme_path
  theme_path="$(resolve_theme_path "$1")"
  [[ -z "$theme_path" ]] && return 1
  "$script_dir/generate-gtk-css" "$theme_path"
}

theme_list() {
  local -a names=()
  mapfile -t names < <(themes_all)
  if [[ ${#names[@]} -eq 0 ]]; then
    echo "No themes found"
    return 0
  fi

  local current
  current="$(active_theme)"

  # Compute column widths
  local name_width=5   # "Theme"
  local source_width=6 # "Source"
  local name src
  for name in "${names[@]}"; do
    if ((${#name} > name_width)); then name_width=${#name}; fi
    src="$(dirname "$(resolve_theme_path "$name")")"
    if ((${#src} > source_width)); then source_width=${#src}; fi
  done

  # Print table
  printf "%-${name_width}s  %s\n" "Theme" "Source"
  for name in "${names[@]}"; do
    local suffix=""
    [[ "$name" == "$current" ]] && suffix="  (active)"
    printf "%-${name_width}s  %s%s\n" "$name" "$(dirname "$(resolve_theme_path "$name")")" "$suffix"
  done
}

theme_set() {
  local name="$1"

  if ! theme_exists "$name"; then
    echo "error: theme '$name' not found" >&2
    echo "" >&2
    echo "Available themes:" >&2
    themes_all | sed 's/^/  /' >&2
    exit 1
  fi

  local current
  current="$(active_theme)"
  if [[ "$name" == "$current" ]]; then
    echo "Already using theme '$name'"
    return 0
  fi

  ipc theme set "$name"
  update_gtk_css "$name"
}

theme_refresh() {
  local current
  current="$(active_theme)"

  if ! theme_exists "$current"; then
    die "active theme '$current' not found"
  fi

  update_gtk_css "$current"
  echo "GTK CSS regenerated for '$current'"
}

# -- profile -----------------------------------------------------------------

profile_current() {
  json_get "$GENERAL_JSON" '.activeProfileName'
}

profile_list() {
  local active_dir
  active_dir="$(json_get "$GENERAL_JSON" '.activeProfile')"

  local -a names=()
  local -a dirs=()
  local name dir
  while IFS=$'\t' read -r name dir; do
    names+=("$name")
    dirs+=("$dir")
  done < <(json_get "$GENERAL_JSON" '.profiles[]? | [.name, .dir] | @tsv')

  if [[ ${#names[@]} -eq 0 ]]; then
    echo "No profiles found"
    return 0
  fi

  # Compute column widths
  local name_width=7 # "Profile"
  local path_width=4 # "Path"
  for i in "${!names[@]}"; do
    if (( ${#names[$i]} > name_width )); then name_width=${#names[$i]}; fi
    local path="$DATA_DIR/${dirs[$i]}"
    if (( ${#path} > path_width )); then path_width=${#path}; fi
  done

  # Print table
  printf "%-${name_width}s  %s\n" "Profile" "Path"
  for i in "${!names[@]}"; do
    local suffix=""
    [[ "${dirs[$i]}" == "$active_dir" ]] && suffix="  (active)"
    printf "%-${name_width}s  %s%s\n" "${names[$i]}" "$DATA_DIR/${dirs[$i]}" "$suffix"
  done
}

# -- wallpaper ---------------------------------------------------------------

wallpaper_set() {
  local path="$1"
  [[ -f "$path" ]] || die "wallpaper file not found: $path"
  ipc wallpaper set "$path"
}

wallpaper_restore() {
  local fallback="${1:-}"

  # Read active profile dir, then the saved wallpaper from profile state
  local profile_dir wallpaper=""
  profile_dir="$(json_get "$GENERAL_JSON" '.activeProfile')"
  if [[ -n "$profile_dir" ]]; then
    wallpaper="$(json_get "$DATA_DIR/${profile_dir}/wallpaper.json" '.currentWallpaper')"
  fi

  # Fall back if no saved wallpaper or file is missing
  if [[ -z "$wallpaper" || ! -f "$wallpaper" ]]; then
    if [[ -n "$fallback" && -f "$fallback" ]]; then
      wallpaper="$fallback"
    else
      echo "No saved wallpaper found" >&2
      return 1
    fi
  fi

  # Detect compositor and apply
  if [[ -n "${SWAYSOCK:-}" || -n "${I3SOCK:-}" ]]; then
    swaymsg output '*' bg "$wallpaper" fill
  else
    # Niri or other wlroots compositor: manage swaybg directly
    pkill -x swaybg 2>/dev/null || true
    sleep 0.1
    swaybg -o '*' -i "$wallpaper" -m fill &
    disown
  fi
}

# -- usage (generated from the registry) ---------------------------------------

usage() {
  echo "Usage: dshell <command> [subcommand]"
  echo ""
  echo "Commands:"

  local width=0 rec group desc
  for rec in "${GROUP_DESCRIPTIONS[@]}"; do
    group="${rec%%|*}"
    if ((${#group} > width)); then width=${#group}; fi
  done
  for rec in "${GROUP_DESCRIPTIONS[@]}"; do
    IFS='|' read -r group desc <<<"$rec"
    printf "  %-${width}s  %s\n" "$group" "$desc"
  done
}

# Usage for a command prefix (e.g. "bar" or "bar focus"), listing every
# registry row underneath it.
prefix_usage() {
  local prefix="$*"
  echo "Usage: dshell $prefix <subcommand>"
  echo ""
  echo "Subcommands:"

  local -a lefts=() descs=()
  local rec path handler spec desc left width=0
  for rec in "${COMMANDS[@]}"; do
    IFS='|' read -r path handler spec desc <<<"$rec"
    [[ "$path" == "$prefix "* ]] || continue
    left="${path#"$prefix" }"
    if [[ -n "$spec" ]]; then
      left="$left $(display_spec "$spec")"
    fi
    lefts+=("$left")
    descs+=("$desc")
    if ((${#left} > width)); then width=${#left}; fi
  done

  local i
  for i in "${!lefts[@]}"; do
    printf "  %-${width}s  %s\n" "${lefts[$i]}" "${descs[$i]}"
  done
}

# -- completion (`dshell --complete <words…>`) ---------------------------------
#
# Prints candidates for the word following the given ones. Emits the
# sentinel "__files__" when the shell should fall back to filename
# completion. Consumed by bin/dshell-completion.bash.

complete_words() {
  local -a argv=("$@")
  local -A seen=()
  local rec path handler spec desc

  for rec in "${COMMANDS[@]}"; do
    IFS='|' read -r path handler spec desc <<<"$rec"
    local -a pwords=()
    read -ra pwords <<<"$path"
    local np=${#pwords[@]} na=${#argv[@]}
    local ok=true i

    if ((na < np)); then
      # Completing a path word
      for ((i = 0; i < na; i++)); do
        if [[ "${argv[$i]}" != "${pwords[$i]}" ]]; then
          ok=false
          break
        fi
      done
      if $ok; then
        seen["${pwords[$na]}"]=1
      fi
    else
      # Completing an argument: the path must match exactly
      for ((i = 0; i < np; i++)); do
        if [[ "${argv[$i]}" != "${pwords[$i]}" ]]; then
          ok=false
          break
        fi
      done
      $ok || continue

      local -a spec_tokens=()
      if [[ -n "$spec" ]]; then
        read -ra spec_tokens <<<"$spec"
      fi
      local idx=$((na - np))
      ((idx < ${#spec_tokens[@]})) || continue

      local src="${spec_tokens[$idx]}"
      src="${src:1:${#src}-2}" # strip <> or []
      src="${src##*:}"
      case "$src" in
      theme) themes_all ;;
      profile) profile_names ;;
      category) settings_categories ;;
      popup) popup_modules ;;
      file) echo "__files__" ;;
      esac
      return 0
    fi
  done

  if ((${#seen[@]} > 0)); then
    printf '%s\n' "${!seen[@]}" | sort
  fi
  return 0
}

# -- dispatch ------------------------------------------------------------------

main() {
  command -v jq >/dev/null || die "jq is required"

  case "${1:-}" in
  -h | --help | "")
    usage
    exit 0
    ;;
  --complete)
    shift
    complete_words "$@"
    exit 0
    ;;
  esac

  local -a argv=("$@")
  local rec path handler spec desc

  # Longest registry path that is a prefix of argv
  local best_rec="" best_n=0
  for rec in "${COMMANDS[@]}"; do
    IFS='|' read -r path handler spec desc <<<"$rec"
    local -a pwords=()
    read -ra pwords <<<"$path"
    local n=${#pwords[@]}
    ((n <= ${#argv[@]})) || continue
    local ok=true i
    for ((i = 0; i < n; i++)); do
      if [[ "${argv[$i]}" != "${pwords[$i]}" ]]; then
        ok=false
        break
      fi
    done
    if $ok && ((n > best_n)); then
      best_rec="$rec"
      best_n=$n
    fi
  done

  if [[ -n "$best_rec" ]]; then
    IFS='|' read -r path handler spec desc <<<"$best_rec"
    local -a args=("${argv[@]:$best_n}")

    # Validate argument count against the spec
    local -a spec_tokens=()
    if [[ -n "$spec" ]]; then
      read -ra spec_tokens <<<"$spec"
    fi
    local min=0 t
    for t in "${spec_tokens[@]:-}"; do
      [[ "$t" == \<* ]] && min=$((min + 1))
    done
    if ((${#args[@]} < min || ${#args[@]} > ${#spec_tokens[@]})); then
      die "usage: dshell $path${spec:+ $(display_spec "$spec")}"
    fi

    local -a h=()
    read -ra h <<<"$handler"
    case "${h[0]}" in
    ipc) ipc "${h[@]:1}" "${args[@]}" ;;
    fn) "${h[1]}" "${args[@]}" ;;
    esac
    return
  fi

  # No full match: find the longest argv prefix that heads registry paths,
  # then show its usage (bare/-h) or fail on the first unknown word.
  local k=0
  while :; do
    local found=false
    for rec in "${COMMANDS[@]}"; do
      path="${rec%%|*}"
      local -a pwords=()
      read -ra pwords <<<"$path"
      ((k < ${#pwords[@]} && k < ${#argv[@]})) || continue
      local ok=true i
      for ((i = 0; i <= k; i++)); do
        if [[ "${argv[$i]}" != "${pwords[$i]}" ]]; then
          ok=false
          break
        fi
      done
      if $ok; then
        found=true
        break
      fi
    done
    $found || break
    k=$((k + 1))
  done

  if ((k == 0)); then
    die "unknown command: ${argv[0]}"
  fi

  local next="${argv[$k]:-}"
  if [[ -z "$next" || "$next" == "-h" || "$next" == "--help" ]]; then
    prefix_usage "${argv[@]:0:$k}"
    exit 0
  fi
  die "unknown subcommand: ${argv[*]:0:$k} $next"
}

main "$@"
